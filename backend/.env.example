# Puerto del servidor
PORT=3000

# JWT
JWT_SECRET=cambiar_por_secreto_seguro_en_produccion
JWT_EXPIRES_IN=7d

# OpenRouter (proveedor primario)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat

# DeepSeek (proveedor de respaldo)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Base de datos
DB_PATH=./data/guyunusa.db

# Entorno
NODE_ENV=development

# CORS - origins permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Pasarela de pagos ──────────────────────────────

# Plan Pro — precio en USD
PRO_PRICE_USD=6.00
PRO_PLAN_LABEL=Guyunusa Pro

# URL base pública del backend (para webhooks y redirects)
# En desarrollo: http://localhost:3000
# En producción: https://api.guyunusa.uy
APP_PUBLIC_URL=http://localhost:3000

# URL del frontend (para redirect post-pago)
FRONTEND_URL=http://127.0.0.1:5500

# Mercado Pago
# Obtener en: https://www.mercadopago.com.uy/developers/panel
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_WEBHOOK_SECRET=tu_webhook_secret_mp

# PayPal
# Obtener en: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=REEMPLAZAR_CON_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REEMPLAZAR_CON_PAYPAL_CLIENT_SECRET
# sandbox | live
PAYPAL_MODE=sandbox

# Google OAuth
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
# Crear "OAuth 2.0 Client ID" de tipo "Web application"
# Agregar en "Authorized JavaScript origins": http://localhost:3000, https://guyunusa.uy
# Agregar en "Authorized redirect URIs": no necesario (usamos popup flow)
GOOGLE_CLIENT_ID=REEMPLAZAR_CON_TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
